# ── AWS / Bedrock ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<YOUR_AWS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET>
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
# Optional managed Bedrock Guardrail (the in-process sanitizer always runs anyway)
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Datadog ──────────────────────────────────────────────────
DD_API_KEY=<YOUR_DATADOG_API_KEY>
DD_APP_KEY=<YOUR_DATADOG_APP_KEY>
DD_SITE=datadoghq.com
DD_LLMOBS_ML_APP=sre-incident-agent
DD_SERVICE=sre-incident-agent
DD_ENV=hackathon

# ── Agent behaviour ──────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8080
APP_SOURCE_DIR=./app_under_test
MAX_ITERATIONS=8
AUTO_REMEDIATE=true

# ── Notifications ────────────────────────────────────────────
# Google Chat incoming-webhook URL the RCA is posted to (key+token embedded).
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/<SPACE>/messages?key=<KEY>&token=<TOKEN>
